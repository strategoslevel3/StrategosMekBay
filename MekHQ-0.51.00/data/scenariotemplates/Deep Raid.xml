                <allowAeroBombs>false</allowAeroBombs>
                <allowedUnitType>-2</allowedUnitType>
                <arrivalTurn>0</arrivalTurn>
                <canReinforceLinked>true</canReinforceLinked>
                <contributesToBV>false</contributesToBV>
